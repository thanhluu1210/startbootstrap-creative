doctype html
html(lang='en')

    head

        meta(charset='utf-8')
        meta(name='viewport', content='width=device-width, initial-scale=1, shrink-to-fit=no')
        meta(name='description', content='HAIPHONG MEDIA LTD - Premier Media Production & Digital Strategy Agency based in London, UK.')
        meta(name='author', content='HAIPHONG MEDIA LTD')

        title HAIPHONG MEDIA LTD | Elite Media Production

        // Favicon
        link(rel='icon', type='image/x-icon', href='assets/favicon.ico')

        // Bootstrap Icons
        link(href='https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css', rel='stylesheet')

        // Google fonts
        link(href='https://fonts.googleapis.com/css?family=Merriweather+Sans:400,700', rel='stylesheet')
        link(href='https://fonts.googleapis.com/css?family=Merriweather:400,300,300italic,400italic,700,700italic', rel='stylesheet', type='text/css')

        // SimpleLightbox plugin CSS
        link(href='https://cdnjs.cloudflare.com/ajax/libs/SimpleLightbox/2.1.0/simpleLightbox.min.css', rel='stylesheet')

        // Core theme CSS (includes Bootstrap)
        link(href='css/styles.css', rel='stylesheet')

    body#page-top

        // Navigation
        nav#mainNav.navbar.navbar-expand-lg.navbar-light.fixed-top.py-3
            .container.px-4.px-lg-5
                a.navbar-brand(href='#page-top') HAIPHONG MEDIA LTD
                button.navbar-toggler.navbar-toggler-right(type='button', data-bs-toggle='collapse', data-bs-target='#navbarResponsive', aria-controls='navbarResponsive', aria-expanded='false', aria-label='Toggle navigation')
                    span.navbar-toggler-icon
                #navbarResponsive.collapse.navbar-collapse
                    ul.navbar-nav.ms-auto.my-2.my-lg-0
                        li.nav-item
                            a.nav-link(href='#about') About
                        li.nav-item
                            a.nav-link(href='#services') Services
                        li.nav-item
                            a.nav-link(href='#portfolio') Portfolio
                        li.nav-item
                            a.nav-link(href='#contact') Contact

        // Masthead
        header.masthead
            .container.px-4.px-lg-5.h-100
                .row.gx-4.gx-lg-5.h-100.align-items-center.justify-content-center.text-center
                    .col-lg-8.align-self-end
                        h1.text-white.font-weight-bold INSPIRING VISUAL MASTERPIECES FOR THE DIGITAL ERA
                        hr.divider
                    .col-lg-8.align-self-baseline
                        p.text-white-75.mb-5 High-impact video production, next-generation creative technology, and powerful cinematic storytelling designed to elevate premium brands worldwide.
                        a.btn.btn-primary.btn-xl(href='#about') Discover Our Work

        // About
        section#about.page-section.bg-primary
            .container.px-4.px-lg-5
                .row.gx-4.gx-lg-5.justify-content-center
                    .col-lg-8.text-center
                        h2.text-white.mt-0 Shaping Global Perspectives
                        hr.divider.divider-light
                        p.text-white-75.mb-4 Based in London, HAIPHONG MEDIA LTD is an elite visual production house. We seamlessly blend traditional cinematic craftsmanship with vanguard digital intelligence to engineer breathtaking visual landscapes. From compelling commercial narratives to hyper-realistic multi-platform assets, we empower visionaries to lead industry trends and captivate modern audiences.
                        a.btn.btn-light.btn-xl(href='#services') Our Core Capabilities

        // Services
        section#services.page-section.bg-white
            .container.px-4.px-lg-5
                h2.text-center.mt-0 Premium Ecosystem
                hr.divider
                .row.gx-4.gx-lg-5
                    .col-lg-3.col-md-6.text-center
                        .mt-5
                            .mb-3
                                i.bi-camera-video.fs-1.text-primary
                            h3.h5.font-weight-bold.mb-2 Video Production
                            p.text-muted.mb-0 High-end brand documentaries, premium commercials, and artistic content built to engage and convert.
                    .col-lg-3.col-md-6.text-center
                        .mt-5
                            .mb-3
                                i.bi-cpu.fs-1.text-primary
                            h3.h5.font-weight-bold.mb-2 Creative Tech
                            p.text-muted.mb-0 Utilizing high-fidelity rendering systems, advanced virtual animations, and cutting-edge media asset pipelines.
                    .col-lg-3.col-md-6.text-center
                        .mt-5
                            .mb-3
                                i.bi-magic.fs-1.text-primary
                            h3.h5.font-weight-bold.mb-2 Post-Production
                            p.text-muted.mb-0 Executive-level color grading, seamless visual effects (VFX), and tailored spatial acoustic engineering.
                    .col-lg-3.col-md-6.text-center
                        .mt-5
                            .mb-3
                                i.bi-graph-up-arrow.fs-1.text-primary
                            h3.h5.font-weight-bold.mb-2 Dynamic Strategy
                            p.text-muted.mb-0 Performance-driven cross-platform architecture to accelerate reach, retention, and digital dominance.

        // Portfolio (Được tối ưu thành hệ thống Minimalist Cards cực kỳ sang trọng, loại bỏ chữ Platform quê mùa)
        section#portfolio.page-section.bg-light
            .container.px-4.px-lg-5
                .text-center.mb-5
                    h2.font-weight-bold.mt-0 Platform Ecosystems
                    hr.divider
                    p.text-muted.fs-5 Engineered for flawless optimization and native impact across leading global networks.
                
                .row.gx-4.gx-lg-5.justify-content-center
                    // YouTube
                    .col-lg-4.col-md-6.mb-4
                        .card.border-0.shadow-sm.h-100.text-center.p-4.rounded-3.bg-white
                            .card-body.d-flex.flex-column.justify-content-center.align-items-center
                                i.bi-youtube.fs-2.text-danger.mb-3
                                h3.h5.font-weight-bold.mb-2 YouTube Strategy
                                p.text-muted.small.mb-0 Cinematic documentary assets and authority positioning.
                    
                    // Facebook
                    .col-lg-4.col-md-6.mb-4
                        .card.border-0.shadow-sm.h-100.text-center.p-4.rounded-3.bg-white
                            .card-body.d-flex.flex-column.justify-content-center.align-items-center
                                i.bi-facebook.fs-2.mb-3(style="color: #1877F2;")
                                h3.h5.font-weight-bold.mb-2 Facebook Networks
                                p.text-muted.small.mb-0 Highly targeted advertising models and community growth.
                    
                    // TikTok
                    .col-lg-4.col-md-6.mb-4
                        .card.border-0.shadow-sm.h-100.text-center.p-4.rounded-3.bg-white
                            .card-body.d-flex.flex-column.justify-content-center.align-items-center
                                i.bi-tiktok.fs-2.text-dark.mb-3
                                h3.h5.font-weight-bold.mb-2 TikTok Production
                                p.text-muted.small.mb-0 Retentive micro-content mapping and trend forecasting.
                    
                    // Instagram
                    .col-lg-4.col-md-6.mb-4
                        .card.border-0.shadow-sm.h-100.text-center.p-4.rounded-3.bg-white
                            .card-body.d-flex.flex-column.justify-content-center.align-items-center
                                i.bi-instagram.fs-2.mb-3(style="color: #E1306C;")
                                h3.h5.font-weight-bold.mb-2 Instagram Aesthetics
                                p.text-muted.small.mb-0 Premium visual identity and high-engagement reels.
                    
                    // Twitter-X
                    .col-lg-4.col-md-6.mb-4
                        .card.border-0.shadow-sm.h-100.text-center.p-4.rounded-3.bg-white
                            .card-body.d-flex.flex-column.justify-content-center.align-items-center
                                i.bi-twitter-x.fs-2.text-dark.mb-3
                                h3.h5.font-weight-bold.mb-2 X Communications
                                p.text-muted.small.mb-0 Real-time authority narratives and direct network outreach.
                    
                    // LinkedIn
                    .col-lg-4.col-md-6.mb-4
                        .card.border-0.shadow-sm.h-100.text-center.p-4.rounded-3.bg-white
                            .card-body.d-flex.flex-column.justify-content-center.align-items-center
                                i.bi-linkedin.fs-2.mb-3(style="color: #0077B5;")
                                h3.h5.font-weight-bold.mb-2 LinkedIn Corporate
                                p.text-muted.small.mb-0 B2B high-value campaigns and executive brand influence.

        // Call to action
        section.page-section.bg-dark.text-white
            .container.px-4.px-lg-5.text-center
                h2.mb-4 Ready to scale your brand's presence?
                a.btn.btn-light.btn-xl(href='#contact') Initiate Your Brief

        // Contact
        section#contact.page-section.bg-white
            .container.px-4.px-lg-5
                .row.gx-4.gx-lg-5.justify-content-center
                    .col-lg-8.col-xl-6.text-center.mb-5
                        h2.mt-0.font-weight-bold Let's Build Your Vision
                        hr.divider
                        p.text-muted Partner with us to revolutionize your digital storytelling. Reach out today for corporate dynamic consulting, bespoke pricing models, or production booking.
                
                .row.gx-4.gx-lg-5.justify-content-center
                    // Phone Card
                    .col-lg-4.col-md-6.mb-4
                        .card.border-0.shadow-sm.h-100.text-center.p-4.rounded-3.bg-light
                            .card-body.d-flex.flex-column.justify-content-center.align-items-center
                                .mb-3.bg-white.shadow-sm.rounded-circle.d-flex.align-items-center.justify-content-center(style="width: 60px; height: 60px;")
                                    i.bi-phone.fs-3.text-primary
                                h4.h5.font-weight-bold.mb-2 Direct Line
                                p.text-secondary.mb-0.font-weight-bold 07526000056
                    
                    // Email Card
                    .col-lg-4.col-md-6.mb-4
                        .card.border-0.shadow-sm.h-100.text-center.p-4.rounded-3.bg-light
                            .card-body.d-flex.flex-column.justify-content-center.align-items-center
                                .mb-3.bg-white.shadow-sm.rounded-circle.d-flex.align-items-center.justify-content-center(style="width: 60px; height: 60px;")
                                    i.bi-envelope.fs-3.text-primary
                                h4.h5.font-weight-bold.mb-2 Global Press
                                p.mb-0
                                    a.text-decoration-none.text-primary.font-weight-bold(href='mailto:contact@haiphongmedialtd.com') contact@haiphongmedialtd.com
                    
                    // Address Card
                    .col-lg-4.col-md-8.mb-4
                        .card.border-0.shadow-sm.h-100.text-center.p-4.rounded-3.bg-light
                            .card-body.d-flex.flex-column.justify-content-center.align-items-center
                                .mb-3.bg-white.shadow-sm.rounded-circle.d-flex.align-items-center.justify-content-center(style="width: 60px; height: 60px;")
                                    i.bi-geo-alt.fs-3.text-primary
                                h4.h5.font-weight-bold.mb-2 Headquarters
                                p.text-muted.mb-0.small 181 Pixton Way, Croydon, CR0 9JN, United Kingdom

        // Footer
        footer.bg-light.py-4
            .container.px-4.px-lg-5
                .small.text-center.text-muted Copyright &copy; 2026 - HAIPHONG MEDIA LTD

        // Bootstrap core JS
        script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js')

        // SimpleLightbox plugin JS
        script(src='https://cdnjs.cloudflare.com/ajax/libs/SimpleLightbox/2.1.0/simpleLightbox.min.js')

        // Core theme JS
        script(src='js/scripts.js')

        // SB Forms JS
        script(src='https://cdn.startbootstrap.com/sb-forms-latest.js')
