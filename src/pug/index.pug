doctype html
html(lang='en')

    head

        meta(charset='utf-8')
        meta(name='viewport', content='width=device-width, initial-scale=1, shrink-to-fit=no')
        meta(name='description', content='HAIPHONG MEDIA LTD - Premier Visual Production & Digital Architecture House based in London, UK.')
        meta(name='author', content='HAIPHONG MEDIA LTD')

        title HAIPHONG MEDIA LTD | Elite Cinematic Production

        // Favicon
        link(rel='icon', type='image/x-icon', href='assets/favicon.ico')

        // Bootstrap Icons
        link(href='https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css', rel='stylesheet')

        // Google fonts - Cormorant Garamond (Classic Luxury) & Plus Jakarta Sans (Modern)
        link(href='https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;0,600;0,700;1,400&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap', rel='stylesheet')

        // Core theme CSS
        link(href='css/styles.css', rel='stylesheet')

        // STYLE INJECTION: LUXURY EDITORIAL (HERITAGE MODERN MODE)
        style.
            :root {
                --bg-heritage: #fbf9f4; /* Royal Ivory Warm Canvas */
                --bg-cream: #f4efe3;    /* Fine Linen/Champagne Accent */
                --text-oxford: #111622; /* Deep Midnight Oxford Ink */
                --text-editorial: #4a5264; /* Muted Slate Slate */
                --gold-brass: #b5893d;   /* Antique Classic Brass Gold */
                --border-fine: #dfd7c2;  /* Thin Gallery Line border */
            }
            body {
                font-family: 'Plus Jakarta Sans', sans-serif !important;
                background-color: var(--bg-heritage);
                color: var(--text-oxford);
                letter-spacing: -0.01em;
            }
            .font-classic {
                font-family: 'Cormorant Garamond', serif !important;
            }
            /* Custom Scrollbar - Editorial Style */
            ::-webkit-scrollbar {
                width: 5px;
            }
            ::-webkit-scrollbar-track {
                background: var(--bg-heritage);
            }
            ::-webkit-scrollbar-thumb {
                background: var(--border-fine);
                border-radius: 0px;
            }
            ::-webkit-scrollbar-thumb:hover {
                background: var(--gold-brass);
            }
            /* Navigation - Transparent Glass Editorial */
            #mainNav {
                background-color: rgba(251, 249, 244, 0.9) !important;
                backdrop-filter: blur(12px);
                -webkit-backdrop-filter: blur(12px);
                border-bottom: 1px solid var(--border-fine);
                box-shadow: 0 2px 20px rgba(181,137,61,0.03);
                transition: all 0.4s ease;
            }
            #mainNav.navbar-shrink {
                padding-top: 0.8rem !important;
                padding-bottom: 0.8rem !important;
                background-color: var(--bg-heritage) !important;
            }
            #mainNav .navbar-brand {
                color: var(--text-oxford) !important;
                font-family: 'Cormorant Garamond', serif !important;
                font-weight: 700 !important;
                letter-spacing: 3px;
                font-size: 1.3rem;
            }
            #mainNav .nav-link {
                color: var(--text-oxford) !important;
                font-weight: 600;
                font-size: 0.75rem;
                text-transform: uppercase;
                letter-spacing: 2px;
                padding: 0.5rem 1.2rem !important;
                transition: all 0.3s ease;
                opacity: 0.8;
            }
            #mainNav .nav-link:hover {
                color: var(--gold-brass) !important;
                opacity: 1;
            }
            /* Hero Masthead - Prestige Gallery Studio Look */
            .masthead {
                background: var(--bg-heritage) !important;
                padding: 20rem 0 16rem 0 !important;
                position: relative;
            }
            .masthead::before {
                content: '';
                position: absolute;
                bottom: 0; left: 10%; width: 80%; height: 1px;
                background-color: var(--border-fine);
            }
            h1 {
                font-family: 'Cormorant Garamond', serif !important;
                font-size: calc(2.8rem + 3vw) !important;
                font-weight: 600 !important;
                line-height: 1.05;
                letter-spacing: -0.02em;
                color: var(--text-oxford);
                margin-bottom: 2rem;
                font-style: italic;
            }
            h1 span {
                font-style: normal !important;
                display: block;
                font-weight: 700;
                letter-spacing: -0.01em;
            }
            hr.divider, hr.divider-dark {
                display: none !important;
            }
            /* Editorial Premium Buttons */
            .btn-xl {
                padding: 1.3rem 2.8rem !important;
                font-size: 0.75rem !important;
                font-weight: 700 !important;
                text-transform: uppercase !important;
                letter-spacing: 2.5px !important;
                border-radius: 0px !important; /* Sharp corners for classic museum luxury look */
                transition: all 0.4s cubic-bezier(0.19, 1, 0.22, 1) !important;
            }
            .btn-neon {
                background-color: var(--text-oxford) !important;
                color: var(--bg-heritage) !important;
                border: 1px solid var(--text-oxford) !important;
            }
            .btn-neon:hover {
                transform: translateY(-4px);
                background-color: var(--gold-brass) !important;
                border-color: var(--gold-brass) !important;
                color: #ffffff !important;
                box-shadow: 0 10px 25px rgba(181,137,61,0.15);
            }
            .btn-outline-neon {
                background-color: transparent !important;
                color: var(--text-oxford) !important;
                border: 1px solid var(--border-fine) !important;
            }
            .btn-outline-neon:hover {
                background-color: rgba(18,24,37,0.02) !important;
                border-color: var(--text-oxford) !important;
                transform: translateY(-4px);
            }
            /* Section Titles */
            .section-title {
                font-family: 'Cormorant Garamond', serif !important;
                font-size: calc(2.2rem + 1.2vw) !important;
                font-weight: 600 !important;
                line-height: 1.15;
                color: var(--text-oxford);
            }
            .subtitle-vanguard {
                font-family: 'Plus Jakarta Sans', sans-serif !important;
                text-transform: uppercase;
                letter-spacing: 3px;
                font-size: 0.75rem;
                color: var(--gold-brass);
                font-weight: 700;
                display: inline-block;
                margin-bottom: 1rem;
            }
            /* Studio Capability Cards */
            .service-box-card {
                background: var(--bg-heritage);
                border: 1px solid var(--border-fine);
                padding: 4.5rem 2rem;
                border-radius: 0px;
                transition: all 0.4s ease;
                position: relative;
            }
            .service-box-card:hover {
                background-color: var(--bg-cream);
                transform: translateY(-5px);
                border-color: var(--gold-brass);
            }
            .service-icon {
                font-size: 2.5rem;
                color: var(--text-oxford);
                margin-bottom: 2rem;
                display: inline-block;
                transition: color 0.3s ease;
            }
            .service-box-card:hover .service-icon {
                color: var(--gold-brass);
            }
            /* Bespoke Dynamic Lookbook Grid (Ecosystems Section) */
            .lookbook-grid {
                display: grid;
                grid-template-columns: repeat(3, 1fr);
                gap: 2.5rem;
            }
            @media (max-width: 992px) {
                .lookbook-grid { grid-template-columns: repeat(2, 1fr); }
            }
            @media (max-width: 650px) {
                .lookbook-grid { grid-template-columns: 1fr; }
            }
            .lookbook-card {
                background: #ffffff;
                border: 1px solid var(--border-fine);
                border-radius: 0px;
                padding: 3.5rem 2.5rem;
                min-height: 380px;
                transition: all 0.5s cubic-bezier(0.25, 1, 0.5, 1);
                position: relative;
                display: flex;
                flex-column: column;
                justify-content: space-between;
            }
            .lookbook-card:hover {
                transform: scale(1.02);
                border-color: var(--text-oxford);
                box-shadow: 0 30px 60px rgba(18,24,37,0.05);
            }
            /* Heritage Big Numbers */
            .lookbook-number {
                font-family: 'Cormorant Garamond', serif !important;
                font-size: 3.5rem;
                font-weight: 300;
                color: var(--border-fine);
                line-height: 1;
                position: absolute;
                top: 2.5rem; right: 2.5rem;
                transition: color 0.4s ease;
            }
            .lookbook-card:hover .lookbook-number {
                color: var(--gold-brass);
                font-weight: 500;
            }
            /* Contact UI Elements */
            .contact-block {
                background: #ffffff;
                border-radius: 0px;
                padding: 3rem 2rem;
                border: 1px solid var(--border-fine);
                transition: all 0.4s ease;
            }
            .contact-block:hover {
                border-color: var(--text-oxford);
                box-shadow: 0 15px 40px rgba(0,0,0,0.03);
            }
            .contact-icon {
                color: var(--gold-brass);
                font-size: 1.5rem;
            }

