doctype html
html(lang='en')

    head
        meta(charset='utf-8')
        meta(name='viewport', content='width=device-width, initial-scale=1, shrink-to-fit=no')
        title HAIPHONG MEDIA LTD | Architectural Media
        link(href='https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&family=Playfair+Display:ital,wght@0,600;1,600&display=swap', rel='stylesheet')
        link(href='https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css', rel='stylesheet')
        
        style.
            :root {
                --bg: #fdfdfd;
                --text: #1a1a1a;
                --accent: #2c3e50;
                --subtle: #95a5a6;
            }
            body { 
                font-family: 'Inter', sans-serif; 
                background-color: var(--bg); 
                color: var(--text);
                line-height: 1.6;
            }
            h1, h2, h3 { font-family: 'Playfair Display', serif; color: var(--accent); }
            
            #mainNav { background: rgba(253, 253, 253, 0.9); border-bottom: 1px solid #eee; }
            .navbar-brand { font-weight: 700; letter-spacing: 2px; color: var(--accent) !important; }
            
            .masthead { padding: 12rem 0; background: #fdfdfd; }
            .hero-img { border-radius: 20px; overflow: hidden; box-shadow: 0 20px 40px rgba(0,0,0,0.05); }
            
            .card-minimal { 
                background: #fff; 
                border: 1px solid #f0f0f0; 
                padding: 3rem; 
                transition: transform 0.4s ease;
            }
            .card-minimal:hover { transform: translateY(-10px); border-color: #ddd; }
            
            .btn-custom { 
                padding: 1rem 2.5rem; border: 1px solid var(--accent); 
                background: transparent; color: var(--accent); font-weight: 600; 
            }
            .btn-custom:hover { background: var(--accent); color: #fff; }

    body
        nav#mainNav.navbar.navbar-expand-lg.fixed-top
            .container
                a.navbar-brand(href='#') HAIPHONG MEDIA
                .navbar-nav.ms-auto
                    a.nav-link(href='#about') About | Services | Portfolio | Contact

        header.masthead
            .container
                .row.align-items-center
                    .col-lg-6
                        h1(style="font-size: 4rem;") Visual Art for Modern Brands.
                        p.lead.my-4(style="color: var(--subtle);") We craft cinematic narratives and high-fidelity media assets for premium global entities.
                        a.btn.btn-custom(href='#contact') Initiate Brief
                    .col-lg-6
                        .hero-img
                            img.img-fluid(src="https://images.unsplash.com/photo-1550745165-9bc0b252726f?q=80&w=1000", alt="Studio")

        section#about.py-5
            .container.py-5
                .row.justify-content-center
                    .col-lg-8.text-center
                        h2(style="font-size: 2.5rem;") A Boutique Approach
                        p.mt-4(style="color: var(--subtle);") Our philosophy is rooted in minimalism and precision. Every frame is calculated, every asset is designed to elevate your brand authority.

        section#portfolio.py-5(style="background: #f7f7f7;")
            .container.py-5
                .row
                    .col-md-4
                        .card-minimal
                            img.img-fluid.mb-3(src="https://images.unsplash.com/photo-1574717024653-61fd2cf4d44d?q=80&w=500", alt="Project")
                            h3 Editorial Style
                            p High-end visual storytelling.
                    .col-md-4
                        .card-minimal
                            img.img-fluid.mb-3(src="https://images.unsplash.com/photo-1599305445671-ac291c95aaa9?q=80&w=500", alt="Project")
                            h3 Digital Precision
                            p Advanced media pipelines.
                    .col-md-4
                        .card-minimal
                            img.img-fluid.mb-3(src="https://images.unsplash.com/photo-1522202176988-66273c2fd55f?q=80&w=500", alt="Project")
                            h3 Brand Identity
                            p Strategic creative consulting.

        footer.text-center.py-5
            p(style="color: var(--subtle);") &copy; 2026 HAIPHONG MEDIA LTD. LONDON.
