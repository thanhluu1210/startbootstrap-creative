doctype html
html(lang='en')

    head

        meta(charset='utf-8')
        meta(name='viewport', content='width=device-width, initial-scale=1, shrink-to-fit=no')
        meta(name='description', content='HAIPHONG MEDIA LTD - Premier Visual Production & Digital Architecture House based in London, UK.')
        meta(name='author', content='HAIPHONG MEDIA LTD')

        title HAIPHONG MEDIA LTD | Elite Cinematic Production

        // Favicon
        link(rel='icon', type='image/x-icon', href='assets/favicon.ico')

        // Bootstrap Icons
        link(href='https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css', rel='stylesheet')

        // Google fonts
        link(href='https://fonts.googleapis.com/css?family=Merriweather+Sans:400,700', rel='stylesheet')
        link(href='https://fonts.googleapis.com/css?family=Merriweather:400,300,300italic,400italic,700,700italic', rel='stylesheet', type='text/css')

        // SimpleLightbox plugin CSS
        link(href='https://cdnjs.cloudflare.com/ajax/libs/SimpleLightbox/2.1.0/simpleLightbox.min.css', rel='stylesheet')

        // Core theme CSS (includes Bootstrap)
        link(href='css/styles.css', rel='stylesheet')

        // High-End Custom Global Overrides (Triệt tiêu hoàn toàn màu cam cũ của template)
        style.
            :root {
                --luxury-black: #0a0a0c;
                --luxury-dark: #121215;
                --luxury-card: #1a1a1e;
                --luxury-silver: #86868b;
                --luxury-light: #f5f5f7;
                --pure-white: #ffffff;
            }
            body {
                background-color: var(--luxury-black);
                color: var(--pure-white);
            }
            #mainNav {
                background-color: transparent !important;
                backdrop-filter: blur(20px);
                -webkit-backdrop-filter: blur(20px);
                transition: all 0.4s ease;
                border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            }
            #mainNav.navbar-shrink {
                background-color: rgba(10, 10, 12, 0.95) !important;
                box-shadow: 0 4px 30px rgba(0, 0, 0, 0.2);
            }
            #mainNav .navbar-brand {
                color: var(--pure-white) !important;
                font-weight: 700 !important;
                letter-spacing: 2px;
            }
            #mainNav .nav-link {
                color: rgba(255, 255, 255, 0.7) !important;
                font-weight: 600 !important;
                letter-spacing: 1px;
                font-size: 0.85rem;
            }
            #mainNav .nav-link:hover {
                color: var(--pure-white) !important;
            }
            .masthead {
                background: linear-gradient(180deg, #020202 0%, var(--luxury-dark) 100%) !important;
                padding-top: 12rem !important;
                padding-bottom: 12rem !important;
            }
            h1, h2, h3, h4 {
                letter-spacing: 0.5px !important;
            }
            hr.divider {
                border-color: var(--pure-white) !important;
                background-color: var(--pure-white) !important;
                max-width: 2.5rem !important;
                height: 1px !important;
                opacity: 0.3 !important;
                margin: 2rem auto !important;
            }
            hr.divider-dark {
                border-color: var(--luxury-black) !important;
                background-color: var(--luxury-black) !important;
                max-width: 2.5rem !important;
                height: 1px !important;
                opacity: 0.2 !important;
                margin: 2rem auto !important;
            }
            .btn-xl {
                padding: 1.25rem 2.75rem !important;
                font-size: 0.8rem !important;
                font-weight: 700 !important;
                text-transform: uppercase !important;
                letter-spacing: 2px !important;
                border-radius: 0px !important;
                transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1) !important;
            }
            .btn-editorial-dark {
                background-color: var(--luxury-black) !important;
                color: var(--pure-white) !important;
                border: 1px solid var(--luxury-black) !important;
            }
            .btn-editorial-dark:hover {
                background-color: transparent !important;
                color: var(--luxury-black) !important;
            }
            .btn-outline-custom {
                background-color: transparent !important;
                color: var(--pure-white) !important;
                border: 1px solid rgba(255, 255, 255, 0.3) !important;
            }
            .btn-outline-custom:hover {
                border-color: var(--pure-white) !important;
                background-color: var(--pure-white) !important;
                color: var(--luxury-black) !important;
            }
            .service-icon-box {
                color: var(--luxury-black) !important;
                font-size: 2.5rem;
                margin-bottom: 1.5rem;
                display: inline-block;
            }
            .portfolio-card {
                background-color: var(--luxury-card);
                border: 1px solid rgba(255, 255, 255, 0.03);
                border-radius: 0px;
                transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
            }
            .portfolio-card:hover {
                transform: translateY(-8px);
                border-color: rgba(255, 255, 255, 0.15);
                box-shadow: 0 30px 60px rgba(0, 0, 0, 0.4);
            }
            .platform-icon {
                font-size: 2.25rem;
                opacity: 0.85;
                transition: transform 0.3s ease;
            }
            .portfolio-card:hover .platform-icon {
                transform: scale(1.1);
                opacity: 1;
            }
            .contact-card {
                background-color: var(--luxury-light);
                border: none;
                border-radius: 0px;
                transition: transform 0.3s ease;
            }
            .contact-card:hover {
                transform: translateY(-4px);
            }
            .icon-wrapper-contact {
                width: 50px;
                height: 50px;
                background-color: var(--pure-white);
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                box-shadow: 0 4px 15px rgba(0,0,0,0.02);
            }

    body#page-top

