doctype html
html(lang='en')

    head

        meta(charset='utf-8')
        meta(name='viewport', content='width=device-width, initial-scale=1, shrink-to-fit=no')
        meta(name='description', content='HAIPHONG MEDIA LTD - Premier Visual Production & Digital Architecture House based in London, UK.')
        meta(name='author', content='HAIPHONG MEDIA LTD')

        title HAIPHONG MEDIA LTD | Elite Cinematic Production

        // Favicon
        link(rel='icon', type='image/x-icon', href='assets/favicon.ico')

        // Bootstrap Icons
        link(href='https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css', rel='stylesheet')

        // Google fonts
        link(href='https://fonts.googleapis.com/css?family=Plus+Jakarta+Sans:300,400,500,600,700,800', rel='stylesheet')

        // Core theme CSS
        link(href='css/styles.css', rel='stylesheet')

        // STYLE INJECTION: CINEMATIC NEO-NOIR ULTRA PREMIUM (UPDATED UNIFORM GRID)
        style.
            :root {
                --bg-main: #050508;
                --bg-sub: #0b0b0f;
                --bg-card: #0d0d14;
                --accent: #e5a93b;
                --text-muted: #94a3b8;
            }
            body {
                font-family: 'Plus Jakarta Sans', sans-serif !important;
                background-color: var(--bg-main);
                color: #ffffff;
                letter-spacing: -0.01em;
            }
            /* Scrollbar Customization */
            ::-webkit-scrollbar {
                width: 8px;
            }
            ::-webkit-scrollbar-track {
                background: var(--bg-main);
            }
            ::-webkit-scrollbar-thumb {
                background: #22222f;
                border-radius: 4px;
            }
            ::-webkit-scrollbar-thumb:hover {
                background: var(--accent);
            }
            /* Navigation */
            #mainNav {
                background-color: transparent !important;
                backdrop-filter: blur(20px);
                -webkit-backdrop-filter: blur(20px);
                border-bottom: 1px solid rgba(255, 255, 255, 0.04);
                transition: all 0.4s ease;
            }
            #mainNav.navbar-shrink {
                background-color: rgba(5, 5, 8, 0.85) !important;
                border-bottom: 1px solid rgba(255, 255, 255, 0.08);
            }
            #mainNav .navbar-brand {
                color: #ffffff !important;
                font-weight: 800 !important;
                letter-spacing: 3px;
                font-size: 1.1rem;
            }
            #mainNav .nav-link {
                color: rgba(255, 255, 255, 0.65) !important;
                font-weight: 600;
                font-size: 0.8rem;
                text-transform: uppercase;
                letter-spacing: 1.5px;
                padding: 0.5rem 1.2rem !important;
                transition: color 0.3s ease;
            }
            #mainNav .nav-link:hover {
                color: var(--accent) !important;
            }
            /* Hero Masthead */
            .masthead {
                background: radial-gradient(circle at 80% 20%, #16122c 0%, var(--bg-main) 55%) !important;
                padding: 17rem 0 14rem 0 !important;
                position: relative;
                overflow: hidden;
            }
            .masthead::before {
                content: '';
                position: absolute;
                top: 0; left: 0; width: 100%; height: 100%;
                background-image: url('https://www.transparenttextures.com/patterns/stardust.png');
                opacity: 0.15;
                z-index: 0;
                pointer-events: none;
            }
            .masthead .container {
                position: relative;
                z-index: 1;
            }
            h1 {
                font-size: calc(2.4rem + 2.5vw) !important;
                font-weight: 800 !important;
                line-height: 1.1;
                letter-spacing: -0.03em;
                background: linear-gradient(180deg, #ffffff 30%, #a5a5b0 100%);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                margin-bottom: 1.5rem;
            }
            hr.divider, hr.divider-dark {
                display: none !important;
            }
            /* Premium Buttons */
            .btn-xl {
                padding: 1.25rem 2.75rem !important;
                font-size: 0.8rem !important;
                font-weight: 700 !important;
                text-transform: uppercase !important;
                letter-spacing: 2px !important;
                border-radius: 6px !important;
                transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1) !important;
            }
            .btn-neon {
                background-color: var(--accent) !important;
                color: #050508 !important;
                border: 1px solid var(--accent) !important;
                box-shadow: 0 4px 20px rgba(229, 169, 59, 0.15);
            }
            .btn-neon:hover {
                transform: translateY(-4px);
                box-shadow: 0 12px 30px rgba(229, 169, 59, 0.35);
                background-color: #f3b23e !important;
            }
            .btn-outline-neon {
                background-color: transparent !important;
                color: #ffffff !important;
                border: 1px solid rgba(255, 255, 255, 0.15) !important;
            }
            .btn-outline-neon:hover {
                border-color: var(--accent) !important;
                color: var(--accent) !important;
                transform: translateY(-4px);
                background-color: rgba(229, 169, 59, 0.05) !important;
            }
            /* Section Titles */
            .section-title {
                font-size: calc(1.8rem + 1vw) !important;
                font-weight: 800 !important;
                letter-spacing: -0.02em;
                line-height: 1.2;
                background: linear-gradient(135deg, #ffffff 0%, #cbd5e1 100%);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
            }
            .subtitle-vanguard {
                text-transform: uppercase;
                letter-spacing: 3px;
                font-size: 0.8rem;
                color: var(--accent);
                font-weight: 700;
                display: inline-block;
                margin-bottom: 1rem;
            }
            /* Premium Services Cards */
            .service-box-card {
                background: linear-gradient(145deg, #13131a 0%, #0d0d12 100%);
                border: 1px solid rgba(255, 255, 255, 0.03);
                padding: 3.5rem 2.2rem;
                border-radius: 16px;
                transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
                position: relative;
                overflow: hidden;
            }
            .service-box-card::before {
                content: '';
                position: absolute;
                top: 0; left: 0; width: 100%; height: 3px;
                background: linear-gradient(90deg, transparent, var(--accent), transparent);
                opacity: 0;
                transition: opacity 0.3s ease;
            }
            .service-box-card:hover {
                transform: translateY(-7px);
                border-color: rgba(255, 255, 255, 0.08);
                box-shadow: 0 20px 40px rgba(0, 0, 0, 0.6);
            }
            .service-box-card:hover::before {
                opacity: 1;
            }
            .service-icon {
                font-size: 2.8rem;
                background: linear-gradient(135deg, #ffffff 0%, var(--accent) 100%);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                margin-bottom: 1.8rem;
                display: inline-block;
            }
            /* Symmetric Ecosystem Grid Layout (NEW) */
            .ecosystem-grid {
                display: grid;
                grid-template-columns: repeat(3, 1fr);
                gap: 2rem;
            }
            @media (max-width: 992px) {
                .ecosystem-grid { grid-template-columns: repeat(2, 1fr); }
            }
            @media (max-width: 768px) {
                .ecosystem-grid { grid-template-columns: 1fr; }
            }
            .ecosystem-card {
                background: var(--bg-card);
                border: 1px solid rgba(255, 255, 255, 0.04);
                border-radius: 20px;
                padding: 3rem 2.2rem;
                min-height: 350px;
                transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
                position: relative;
                overflow: hidden;
            }
            .ecosystem-card:hover {
                transform: translateY(-8px);
                border-color: rgba(229, 169, 59, 0.35);
                box-shadow: 0 30px 60px rgba(0,0,0,0.75), 0 0 20px rgba(229, 169, 59, 0.03);
            }
            /* Tech Image Overlay System */
            .ecosystem-img-overlay {
                position: absolute;
                top: 0; left: 0; width: 100%; height: 100%;
                background-size: cover;
                background-position: center;
                /* Luxury High-Contrast Gradient Mask */
                background-image: linear-gradient(135deg, rgba(13, 13, 20, 0.98) 40%, rgba(13, 13, 20, 0.8) 100%), var(--bg-img);
                opacity: 0.4;
                transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
                z-index: 0;
            }
            .ecosystem-card:hover .ecosystem-img-overlay {
                opacity: 0.6;
                transform: scale(1.06);
            }
            .ecosystem-card-content {
                position: relative;
                z-index: 1;
                height: 100%;
            }
            /* Contact UI Elements */
            .contact-block {
                background: linear-gradient(145deg, #111116 0%, #08080c 100%);
                border-radius: 14px;
                padding: 2.2rem;
                border: 1px solid rgba(255, 255, 255, 0.03);
                transition: all 0.3s ease;
            }
            .contact-block:hover {
                border-color: rgba(255, 255, 255, 0.08);
                background: linear-gradient(145deg, #14141a 0%, #0b0b0f 100%);
            }
            .contact-icon {
                color: var(--accent);
                font-size: 1.8rem;
            }

